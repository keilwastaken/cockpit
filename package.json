{
  "name": "cockpit",
  "version": "0.1.0",
  "description": "Portable workflow skills for context-efficient, evidence-driven coding agents.",
  "type": "module",
  "main": ".opencode/plugins/cockpit.js",
  "keywords": [
    "pi-package",
    "opencode",
    "claude-code",
    "skills",
    "coding-agent",
    "workflow"
  ],
  "license": "MIT",
  "files": [
    ".opencode",
    ".claude-plugin",
    "agents",
    "commands",
    "docs",
    "evals",
    "extensions",
    "hooks",
    "scripts",
    "skills",
    "icon.png",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test": "node --test tests/*.test.js",
    "check": "npm test && npm run check:generated",
    "check:generated": "node scripts/generate-adapters.mjs --check",
    "generate": "node scripts/generate-adapters.mjs",
    "eval": "node scripts/run-behavioral-evals.mjs"
  },
  "pi": {
    "skills": [
      "./skills"
    ],
    "extensions": [
      "./extensions/cockpit.js"
    ]
  }
}
